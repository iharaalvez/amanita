{
  "name": "livedex-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed": "docker compose -f backend/docker-compose.yml --profile seed run --rm seeder",
    "seed:forms": "tsx scripts/seed-cosmetic-forms.ts",
