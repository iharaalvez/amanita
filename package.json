    "backend:down": "docker compose -f backend/docker-compose.yml down"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.8",
    "idb-keyval": "^6.2.2",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
